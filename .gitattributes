# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source code
*.py text diff=python
*.sh text eol=lf

# LFS: Images
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
